# Copy to .env and fill in values before running docker compose up.

# Required in production — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Optional: HTTP Basic Auth for the web UI (both must be set to enable)
# CRASHOMON_AUTH_USER=admin
# CRASHOMON_AUTH_PASS=changeme

# Optional: API key required on X-API-Key header for /api/* endpoints
# CRASHOMON_API_KEY=changeme
