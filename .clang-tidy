Checks: >
  -*,
  bugprone-*,
  cert-*,
  -cert-err33-c,           # Requires checking return values of POSIX/stdio functions (close,
                           # unlink, mkdir, setsockopt, fwrite, sigaction, …). We intentionally
                           # ignore these in best-effort cleanup paths (shutdown, stale-socket
                           # removal, mkdir for dirs that may already exist) where there is no
                           # meaningful recovery action. (void)-casting every call obscures intent
                           # without adding safety.
  clang-analyzer-*,
  cppcoreguidelines-*,
  misc-*,
  -misc-include-cleaner,    # False positives on POSIX/Crashpad headers included transitively;
                            # suppress globally rather than annotating every callsite.
  modernize-*,
  -modernize-use-trailing-return-type,
  performance-*,
  readability-*,
WarningsAsErrors: "*"
HeaderFilterRegex: "(lib|daemon|tools|test)/.*"
CheckOptions:
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionIgnoredRegexp
    value: "^crashomon_.*"
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.ConstantCase
    value: CamelCase
  - key: readability-identifier-naming.ConstantPrefix
    value: k
  # Local const variables follow the same lower_case rule as other locals.
  # Only namespace/class/static-scope constants get the k prefix.
  - key: readability-identifier-naming.LocalConstantCase
    value: lower_case
  - key: readability-identifier-naming.StaticConstantCase
    value: CamelCase
  - key: readability-identifier-naming.StaticConstantPrefix
    value: k
  - key: readability-identifier-naming.EnumConstantCase
    value: CamelCase
  - key: readability-identifier-naming.EnumConstantPrefix
    value: k
  - key: readability-identifier-naming.MemberCase
    value: lower_case
  - key: readability-identifier-naming.PrivateMemberSuffix
    value: _
