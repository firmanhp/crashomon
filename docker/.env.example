# Copy this file to .env and fill in values before running:
#   cp .env.example .env
#   docker compose up -d

# Flask session and CSRF signing key — MUST be changed before production use.
# Generate a new one: openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Data directory paths inside the container (leave as-is when using the named volume).
CRASHOMON_SYMBOL_STORE=/data/symbols
CRASHOMON_DB=/data/crashes.db

# Optional: HTTP Basic Auth for the web UI (protects all browser-facing routes).
# CRASHOMON_AUTH_USER=admin
# CRASHOMON_AUTH_PASS=changeme

# Optional: API key for CI/CD uploads to /api/* routes (X-Api-Key header).
# CRASHOMON_API_KEY=
