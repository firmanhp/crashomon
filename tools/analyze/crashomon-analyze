#!/usr/bin/env python3
"""crashomon-analyze — minidump symbolication tool.

Modes:
  crashomon-analyze --store=<dir> [--store=<dir> ...] --minidump=<file.dmp>
      Symbolicate a Breakpad minidump using one or more symbol stores.
      Delegates to minidump-stackwalk --json; build IDs in the minidump auto-match
      to .sym files in the stores.

  crashomon-analyze --symbols=<file.sym> --minidump=<file.dmp>
      Symbolicate a minidump using a single explicit .sym file.
      The file is installed into a temporary Breakpad store layout and
      minidump-stackwalk is invoked against it.

  crashomon-analyze --minidump=<file.dmp>
      Print a raw (unsymbolicated) Android-style tombstone from a minidump.

  crashomon-analyze --store=<dir> [--store=<dir> ...] --sysroot=<dir> --minidump=<file.dmp>
      Symbolicate a minidump against symbol stores, lazily extracting symbols
      for unresolved sysroot libraries on-the-fly via dump_syms.  Extracted
      .sym files are cached in the first store so subsequent runs skip conversion.

Options:
  --stackwalk-binary=<path>   Path to minidump-stackwalk (default: co-located, then PATH)
  --dump-syms-binary=<path>   Path to dump_syms (required for --sysroot; default: co-located, then PATH)

Installation:
  For the host toolkit, crashomon_tools/ is staged alongside this script so
  imports resolve automatically.  For development, run:
    pip install -e tools/
"""

from __future__ import annotations

import sys
from pathlib import Path

_SCRIPT_DIR = Path(__file__).resolve().parent

# Source-tree fallback: package lives one level up from this script's directory.
try:
    import crashomon_tools  # noqa: F401
except ImportError:
    sys.path.insert(0, str(_SCRIPT_DIR.parent))
    import crashomon_tools  # noqa: F401

from crashomon_tools.analyze.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main(_SCRIPT_DIR))
