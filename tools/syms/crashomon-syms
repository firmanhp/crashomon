"""crashomon-syms — Breakpad symbol store management tool.

Wraps dump_syms to ingest debug binaries into the Breakpad symbol store layout:
  <store>/<module_name>/<build_id>/<module_name>.sym

Usage:
  crashomon-syms add  --store <dir> <binary> [<binary> ...]
  crashomon-syms add  --store <dir> --recursive <dir>
  crashomon-syms list --store <dir>
  crashomon-syms prune --store <dir> --keep <n>

This is a stub. Implementation is in Phase 3.
"""

import argparse
import sys


def cmd_add(args: argparse.Namespace) -> int:
    print("crashomon-syms add: stub — implementation pending Phase 3", file=sys.stderr)
    return 1


def cmd_list(args: argparse.Namespace) -> int:
    print("crashomon-syms list: stub — implementation pending Phase 3", file=sys.stderr)
    return 1


def cmd_prune(args: argparse.Namespace) -> int:
    print("crashomon-syms prune: stub — implementation pending Phase 3", file=sys.stderr)
    return 1


def main() -> int:
    parser = argparse.ArgumentParser(description="Crashomon symbol store manager")
    sub = parser.add_subparsers(dest="command", required=True)

    p_add = sub.add_parser("add", help="Ingest debug binary into symbol store")
    p_add.add_argument("--store", required=True, metavar="DIR", help="Symbol store root")
    p_add.add_argument("--recursive", metavar="DIR", help="Recursively search directory for ELFs")
    p_add.add_argument("binaries", nargs="*", metavar="BINARY")
    p_add.add_argument("--dump-syms", default="dump_syms", help="Path to dump_syms binary")

    p_list = sub.add_parser("list", help="List stored symbols")
    p_list.add_argument("--store", required=True, metavar="DIR")

    p_prune = sub.add_parser("prune", help="Remove old symbol versions")
    p_prune.add_argument("--store", required=True, metavar="DIR")
    p_prune.add_argument(
        "--keep", type=int, default=3, metavar="N", help="Keep latest N versions per module"
    )

    args = parser.parse_args()
    dispatch = {"add": cmd_add, "list": cmd_list, "prune": cmd_prune}
    return dispatch[args.command](args)


if __name__ == "__main__":
    sys.exit(main())
