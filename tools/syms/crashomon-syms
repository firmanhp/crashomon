#!/usr/bin/env python3
"""crashomon-syms — Breakpad symbol store management tool.

Wraps dump_syms to ingest debug binaries into the Breakpad symbol store layout:
  <store>/<module_name>/<build_id>/<module_name>.sym

Usage:
  crashomon-syms add   --store <dir> [--dump-syms <path>] <binary> [<binary> ...]
  crashomon-syms add   --store <dir> [--dump-syms <path>] --recursive <dir>
  crashomon-syms add   --store <dir> [--dump-syms <path>] --sysroot <dir>
  crashomon-syms list  --store <dir>
  crashomon-syms prune --store <dir> [--keep <n>]

Installation:
  For the host toolkit, crashomon_tools/ is staged alongside this script so
  imports resolve automatically.  For development, run:
    pip install -e tools/
"""

from __future__ import annotations

import sys
from pathlib import Path

_SCRIPT_DIR = Path(__file__).resolve().parent

# Source-tree fallback: package lives one level up from this script's directory.
try:
    import crashomon_tools  # noqa: F401
except ImportError:
    sys.path.insert(0, str(_SCRIPT_DIR.parent))
    import crashomon_tools  # noqa: F401

from crashomon_tools.syms.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main(_SCRIPT_DIR))
